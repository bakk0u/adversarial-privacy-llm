{
  "project_name": "Adversarial Privacy Attacks on LLMs and Defense via Prompt Engineering",
  "random_seed": 42,
  "default_model_name": "mock",
  "model_backend": {
    "type": "mock",
    "model_name": "mock",
    "base_leak_probability": 0.6,
    "ollama_url": "http://localhost:11434/api/generate"
  },
  "detection": {
    "enable_semantic_matching": false
  },
  "dataset_size": 25,
  "task_types": [
    "summarization",
    "anomaly_detection",
    "recommendation"
  ],
  "attack_types": [
    "direct_extraction",
    "instruction_override",
    "memory_probing",
    "disguised_extraction"
  ],
  "strategy_types": [
    "direct_baseline",
    "policy_first_structured",
    "tree_of_thoughts",
    "skeleton_of_thought",
    "least_to_most"
  ],
  "output_paths": {
    "generated_data_csv": "data/generated/sensitive_records.csv",
    "generated_data_json": "data/generated/sensitive_records.json",
    "run_results_csv": "results/runs/experiment_results.csv",
    "run_results_json": "results/runs/experiment_results.json",
    "aggregated_results_csv": "results/tables/strategy_comparison.csv",
    "aggregated_results_json": "results/tables/strategy_comparison.json",
    "summary_report_md": "results/reports/findings.md",
    "run_metadata_json": "results/runs/run_metadata.json"
  }
}

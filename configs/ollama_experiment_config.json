{
  "project_name": "Adversarial Privacy Attacks on LLMs and Defense via Prompt Engineering - Ollama Validation",
  "random_seed": 42,
  "default_model_name": "llama3.1:8b",
  "model_backend": {
    "type": "ollama",
    "model_name": "llama3.1:8b",
    "fallback_model": "deepseek-r1:8b",
    "temperature": 0.1,
    "num_ctx": 2048,
    "num_predict": 60,
    "ollama_url": "http://localhost:11434/api/generate",
    "timeout_seconds": 30
  },
  "detection": {
    "enable_semantic_matching": false
  },
  "dataset_size": 10,
  "task_types": [
    "summarization",
    "anomaly_detection",
    "recommendation"
  ],
  "attack_types": [
    "direct_extraction",
    "instruction_override",
    "memory_probing",
    "disguised_extraction"
  ],
  "strategy_types": [
    "direct_baseline",
    "policy_first_structured",
    "tree_of_thoughts",
    "skeleton_of_thought",
    "least_to_most"
  ],
  "output_paths": {
    "generated_data_csv": "results/ollama_runs/generated_sensitive_records.csv",
    "generated_data_json": "results/ollama_runs/generated_sensitive_records.json",
    "run_results_csv": "results/ollama_runs/experiment_results.csv",
    "run_results_json": "results/ollama_runs/experiment_results.json",
    "aggregated_results_csv": "results/ollama_runs/strategy_comparison.csv",
    "aggregated_results_json": "results/ollama_runs/strategy_comparison.json",
    "summary_report_md": "results/ollama_runs/findings.md",
    "run_metadata_json": "results/ollama_runs/run_metadata.json",
    "example_cases_md": "results/reports/example_cases.md",
    "plots_dir": "results/ollama_runs/plots"
  }
}
